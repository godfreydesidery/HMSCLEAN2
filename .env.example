# Local development environment variables.
# Copy this file to `.env` (which is git-ignored) and fill in real values.
#
# SECRETS MUST BE STRONG, RANDOM VALUES — never dictionary words or short strings
# like the legacy system used. Generate them, e.g.:
#     openssl rand -base64 48      # for JWT_SECRET (>= 256-bit)
#     openssl rand -base64 24      # for DB_PASSWORD
# Never commit a real .env. CI uses GitHub Actions secrets; staging/prod use a
# secrets store (see docs/adr/0013-build-deploy-runtime.md).

# --- PostgreSQL 16 ---
DB_URL=jdbc:postgresql://localhost:5432/hmis
DB_USERNAME=hmis_app
DB_PASSWORD=__generate_with_openssl_rand_base64_24__

# --- JWT signing (HS256) — 256-bit (>=32 byte) random key, base64-encoded ---
JWT_SECRET=__generate_with_openssl_rand_base64_48__

# --- Added as modules need them (kept out of source) ---
# SMTP_HOST=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# OBJECT_STORE_ACCESS_KEY=
# OBJECT_STORE_SECRET_KEY=
# INSURANCE_API_TOKEN=
